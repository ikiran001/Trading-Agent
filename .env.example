# App
APP_ENV=development
LOG_LEVEL=INFO
TIMEZONE=Asia/Kolkata
USE_TICK_SIMULATOR=true

# Database
DATABASE_URL=postgresql+asyncpg://trading:trading@localhost:5432/trading_agent

# Redis
REDIS_URL=redis://localhost:6379/0

# Zerodha Kite
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# TradingView webhook
TRADINGVIEW_WEBHOOK_SECRET=change-me

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenAI (optional)
OPENAI_API_KEY=

# Risk
CONFIDENCE_THRESHOLD=70
MAX_DAILY_LOSS_PCT=2.0
MAX_CONSECUTIVE_LOSSES=3
MIN_RR_RATIO=1.5
ENABLE_LIVE_TRADING=false

# Symbols
WATCHLIST_SYMBOLS=NIFTY,BANKNIFTY,FINNIFTY

# News RSS
NEWS_RSS_URLS=https://economictimes.indiatimes.com/markets/rssfeeds/1977021501.cms

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/v1/stream
